# Application Security
SECRET_KEY=your-secret-key-here-change-in-production
# JWT signing algorithm (default: HS256)
ALGORITHM=HS256
# Access token expiration time in minutes (default: 30)
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Database
# SQLite async example (default for local development)
DATABASE_URL=sqlite+aiosqlite:///./eventforge.db
# PostgreSQL async example (recommended for production)
# DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/eventforge

# CORS
# Comma-separated list of allowed origins (use specific origins in production)
CORS_ORIGINS=http://localhost:3000,http://localhost:8000